{
  "name": "hrms-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:next": "node -e \"const fs=require('fs');try{fs.rmSync('.next',{recursive:true,force:true});}catch(_){}\"",
    "predev": "npm run clean:next",
    "dev": "next dev",
    "prebuild": "node scripts/generate-app-version.js && npm run clean:next",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@chakra-ui/next-js": "^2.4.2",
    "@chakra-ui/react": "^2.8.2", 
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@hookform/resolvers": "^3.9.0",
    "framer-motion": "^11.3.0",
    "lucide-react": "^0.424.0",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "recharts": "^2.12.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4"
  }
